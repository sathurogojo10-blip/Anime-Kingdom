<!DOCTYPE html>
<html lang="si">
<head>
    <meta charset="UTF-8">
    <title>Anime Kingdom | Official Portal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com" rel="stylesheet">
</head>
<body class="bg-[#050505] text-white font-sans">
    <nav class="flex justify-between items-center px-10 py-6 bg-black/90 sticky top-0 z-50 border-b border-white/5">
        <div class="text-3xl font-black uppercase text-[#ffcc00]">ANIME <span class="text-white">KINGDOM</span></div>
        <div class="w-1/3 relative">
            <input type="text" id="mSearch" oninput="search()" placeholder="Anime සොයන්න..." class="w-full bg-zinc-900 border border-white/10 py-2 px-10 rounded-full outline-none focus:border-[#ffcc00]">
            <i class="fas fa-search absolute left-4 top-3 text-gray-500"></i>
        </div>
    </nav>

    <div class="p-10">
        <h2 class="text-2xl font-bold border-l-4 border-[#ffcc00] pl-4 mb-10 tracking-widest">POPULAR NOW</h2>
        <div id="grid" class="grid grid-cols-2 md:grid-cols-6 gap-8"></div>
    </div>

    <script>
        const API = 'https://graphql.anilist.co';
        async function load(q = '') {
            const query = q ? `query($s:String){Page(perPage:24){media(search:$s,type:ANIME){idMal title{english romaji}coverImage{large}}}}` 
                          : `query{Page(perPage:24){media(sort:TRENDING_DESC,type:ANIME){idMal title{english romaji}coverImage{large}}}}`;
            const res = await fetch(API,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({query,variables:{s:q}})});
            const {data} = await res.json();
            document.getElementById('grid').innerHTML = data.Page.media.map(a => `
                <div class="cursor-pointer group" onclick="watch('${a.idMal}','${(a.title.english||a.title.romaji).replace(/'/g,"")}')">
                    <img src="${a.coverImage.large}" class="h-72 w-full object-cover rounded-xl group-hover:border-2 border-[#ffcc00] transition-all">
                    <p class="mt-3 text-xs font-bold truncate text-center uppercase">${a.title.english||a.title.romaji}</p>
                </div>`).join('');
        }
        function search() { load(document.getElementById('mSearch').value); }
        function watch(id, title) { 
            // Player එකට ID එක සහ Title එක යොමු කරයි
            window.location.href = `https://player.animekingdom.net{id}&title=${encodeURIComponent(title)}`; 
        }
        window.onload = () => load();
    </script>
</body>
</html>
